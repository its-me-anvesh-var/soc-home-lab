<!-- ============================================================
     Custom Wazuh Detection Rules
     Author: Anvesh Raju Vishwaraju
     MITRE ATT&CK Mapped
     ============================================================ -->

<group name="custom_soc_rules,">

  <!-- ── NEW LOCAL USER ACCOUNT CREATED ── -->
  <!-- MITRE: T1136.001 - Create Local Account -->
  <rule id="100001" level="10">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^4720$</field>
    <description>New local user account created: $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>account_change,authentication_success,pci_dss_8.1,</group>
  </rule>

  <!-- ── USER ADDED TO PRIVILEGED GROUP ── -->
  <!-- MITRE: T1098 - Account Manipulation -->
  <rule id="100002" level="12">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^4732$</field>
    <field name="win.eventdata.targetUserName">(?i)administrators|domain admins|enterprise admins</field>
    <description>User added to privileged group: $(win.eventdata.subjectUserName) added $(win.eventdata.memberSid)</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_change,pci_dss_8.1,</group>
  </rule>

  <!-- ── WINDOWS DEFENDER DISABLED ── -->
  <!-- MITRE: T1562.001 - Disable or Modify Tools -->
  <rule id="100003" level="14">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^5001$</field>
    <description>Windows Defender real-time protection disabled on $(win.system.computer)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>defense_evasion,</group>
  </rule>

  <!-- ── AUDIT LOG CLEARED ── -->
  <!-- MITRE: T1070.001 - Clear Windows Event Logs -->
  <rule id="100004" level="15">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^1102$|^104$</field>
    <description>CRITICAL: Security audit log cleared by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1070.001</id>
    </mitre>
    <group>defense_evasion,audit,</group>
  </rule>

  <!-- ── SUSPICIOUS SCHEDULED TASK ── -->
  <!-- MITRE: T1053.005 - Scheduled Task -->
  <rule id="100005" level="10">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^4698$</field>
    <description>New scheduled task created: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,</group>
  </rule>

  <!-- ── MIMIKATZ LSASS ACCESS ── -->
  <!-- MITRE: T1003.001 - LSASS Memory -->
  <rule id="100006" level="15">
    <if_sid>18101</if_sid>
    <field name="win.system.eventID">^4656$</field>
    <field name="win.eventdata.objectName">(?i)lsass</field>
    <description>CRITICAL: LSASS memory access detected - possible credential dumping on $(win.system.computer)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_access,</group>
  </rule>

  <!-- ── SSH BRUTE FORCE ── -->
  <!-- MITRE: T1110.001 - Password Guessing -->
  <rule id="100007" level="10" frequency="10" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <description>SSH brute force attack from $(srcip): $(counter) attempts in 60 seconds</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <same_source_ip />
    <group>authentication_failures,</group>
  </rule>

  <!-- ── FILE INTEGRITY VIOLATION ── -->
  <!-- MITRE: T1565.001 - Stored Data Manipulation -->
  <rule id="100008" level="12">
    <if_sid>550</if_sid>
    <field name="file">(?i)/etc/passwd|/etc/shadow|/etc/sudoers</field>
    <description>Critical system file modified: $(file)</description>
    <mitre>
      <id>T1565.001</id>
    </mitre>
    <group>integrity_monitoring,</group>
  </rule>

</group>
